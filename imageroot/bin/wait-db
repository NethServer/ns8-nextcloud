import sys
import time
import subprocess
import agent

db_env = agent.read_envfile("database.env")
root_password = db_env.get("MARIADB_ROOT_PASSWORD", "nextcloud")

max_tries = 60
i = 0
while i < max_tries:
    i += 1
    print(f"wait-db: waiting for nextcloud-db ({i})", file=sys.stderr)
    p = subprocess.run(
        ['podman', 'exec', 'nextcloud-db', 'mariadb-admin', 'ping',
         '-uroot', f'-p{root_password}', '--silent', '--protocol=tcp', '--port=3306'],
        capture_output=True
    )
    if p.returncode == 0:
        print("wait-db: nextcloud-db is ready", file=sys.stderr)
        sys.exit(0)
    time.sleep(1)

print("wait-db: timeout waiting for nextcloud-db", file=sys.stderr)
sys.exit(1)
