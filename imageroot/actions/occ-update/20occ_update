import json
import subprocess
import sys
import time
import agent

def run_occ(*args):
    cmd = ['podman', 'exec', '--user', 'www-data', 'nextcloud-app', 'php', './occ'] + list(args)
    agent.run_helper(*cmd).check_returncode()

def occ_status():
    cmd = ['podman', 'exec', '--user', 'www-data', 'nextcloud-app', 'php', './occ', 'status', '--output', 'json']
    p = subprocess.run(cmd, capture_output=True)
    return json.loads(p.stdout)

def is_upgrade_running():
    # Match 'occ upgrade' specifically — 'occ status' calls would be a false positive.
    p = subprocess.run(['podman', 'exec', 'nextcloud-app', 'ps', 'ax'], capture_output=True)
    return p.returncode == 0 and b'occ upgrade' in p.stdout

try:
    status = occ_status()
except Exception as ex:
    print(f"occ-update: cannot read occ status: {ex}", file=sys.stderr)
    sys.exit(1)

if not status.get('maintenance') and not status.get('needsDbUpgrade'):
    sys.exit(0)

if status.get('needsDbUpgrade'):
    # Wait up to max_wait for the entrypoint to start and complete occ upgrade.
    # We do not impose a grace period: the entrypoint may take anywhere from 1s to
    # several tens of seconds to launch occ upgrade depending on server load.
    max_wait = 900
    waited = 0
    upgrade_seen = False
    while waited < max_wait:
        time.sleep(5)
        waited += 5
        if is_upgrade_running():
            upgrade_seen = True
        try:
            status = occ_status()
        except Exception:
            continue
        print(f"occ-update: waiting for upgrade… ({waited}s, running={upgrade_seen})", file=sys.stderr)
        if not status.get('needsDbUpgrade'):
            break  # entrypoint completed the upgrade
    else:
        print("occ-update: timed out waiting for upgrade to complete", file=sys.stderr)

    if status.get('needsDbUpgrade'):
        # Either the entrypoint never started occ upgrade, or it ran and failed.
        # Re-run manually as per NC docs.
        # https://docs.nextcloud.com/server/latest/admin_manual/maintenance/manual_upgrade.html#troubleshooting
        # Do NOT run maintenance:mode --off here: with needsDbUpgrade=true the new PHP
        # code is incompatible with the old DB schema and occ upgrade handles
        # maintenance mode internally.
        print("occ-update: needsDbUpgrade still true, running occ upgrade manually…", file=sys.stderr)
        if is_upgrade_running():
            print("occ-update: occ upgrade is already running inside the container, skipping", file=sys.stderr)
            sys.exit(0)
        if status.get('maintenance'):
            # occ upgrade refuses to run if maintenance mode is already set externally.
            # Turn it off first so the upgrade can proceed.
            print("occ-update: turning off maintenance mode before manual upgrade", file=sys.stderr)
            run_occ('maintenance:mode', '--off')
        try:
            run_occ('upgrade')
        except Exception:
            print("occ-update: occ upgrade failed, running maintenance:repair as best-effort recovery", file=sys.stderr)
            run_occ('maintenance:repair')
            raise
    status = occ_status()

if status.get('maintenance'):
    run_occ('maintenance:mode', '--off')
